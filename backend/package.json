{
  "name": "virtual-land-marketplace-backend",
  "version": "1.0.0",
  "description": "Backend for Global Virtual Land Marketplace with Google Spanner",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:asia": "cross-env REGION=asia PORT=5001 node src/server.js",
    "start:us": "cross-env REGION=us PORT=5002 node src/server.js",
    "start:eu": "cross-env REGION=eu PORT=5003 node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/utils/seed.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "mongoose": "^9.2.4",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^2.0.22"
  }
}
